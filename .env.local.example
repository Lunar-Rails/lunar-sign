# ─────────────────────────────────────────────
# Lunar Sign — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Supabase — from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase DB URL — used by pnpm db:migrate to apply SQL migrations
# Get it from: Supabase Dashboard → Settings → Database → Connection string (URI)
# Use the "Transaction" pooler URL (port 6543) for best compatibility
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@[host]:6543/postgres

# Mailtrap SMTP — from Mailtrap > Inboxes > SMTP Settings
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_user
MAILTRAP_PASSWORD=your_mailtrap_password
EMAIL_FROM=noreply@lunarrails.io

# App URL — used to build signing links in emails
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Legal defensibility ────────────────────────────────────────────────────────

# HMAC key for tamper-evident evidence records (64 hex chars).
# Generate: openssl rand -hex 32
EVIDENCE_HMAC_KEY=

# Comma-separated OpenTimestamps calendar URLs (optional; defaults used if unset).
# OTS_CALENDAR_URLS=https://alice.btc.calendar.opentimestamps.org,https://bob.btc.calendar.opentimestamps.org,https://finney.calendar.eternitywall.com

# Shared secret for the internal OTS upgrade cron endpoint (min 16 chars).
# Generate: openssl rand -hex 32
OTS_CRON_SECRET=

# Version tag embedded in the consent text hash (update if consent copy changes).
CONSENT_TEXT_VERSION=2026-04-16
